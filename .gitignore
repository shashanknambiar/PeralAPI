.vs/
*.vsidx
*.vsp
*.vspx
*.sap

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# Roslyn cache
*.cache
*.VC.db
*.VC.opendb
ipch/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets / local config
appsettings.local.json
appsettings.*.local.json
secrets.json
*.pfx
*.p12

# Logs
logs/
*.log

# Test results
TestResults/
coverage/
*.trx
*.coveragexml

# Publish output
publish/
